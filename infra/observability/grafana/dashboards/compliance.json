      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "editorMode": "code", "expr": "sum by (decision) (rate(pdp_decisions_total[$__rate_interval]))", "legendFormat": "{{decision}}", "range": true } ]
    },
