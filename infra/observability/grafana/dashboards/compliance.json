      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "editorMode": "code", "expr": "sum(rate(governance_reviews_run_total[$__rate_interval]))", "legendFormat": "reviews run/s", "range": true } ]
    },
