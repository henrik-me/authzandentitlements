{
  "realm": "authz-bank",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "accessTokenLifespan": 3600,
  "roles": {
    "realm": [
      {
        "name": "Teller",
        "description": "Front-line teller.",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "BranchManager",
        "description": "Branch manager; may approve high-value transactions.",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "ComplianceOfficer",
        "description": "Compliance officer; may approve high-value transactions.",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "Auditor",
        "description": "Read-only auditor.",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "clientScopes": [
    {
      "name": "bank.read",
      "description": "Read access to bank resources.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "bank.transactions.write",
      "description": "Create transactions.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "bank.approvals.write",
      "description": "Approve or reject high-value transactions.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "bank-claims",
      "description": "Emits tenant/branch/roles custom claims and bank-api audience into the access token.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "tenant",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant",
            "claim.name": "tenant",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        },
        {
          "name": "branch",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "branch",
            "claim.name": "branch",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        },
        {
          "name": "roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "true"
          }
        },
        {
          "name": "aud-bank-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "bank-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "preferred_username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "agent.bank.read",
      "description": "Delegated read capability for an agent acting on behalf of a user.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "agent.bank.transactions.write",
      "description": "Delegated create-transaction capability for an agent (OBO).",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "agent.bank.approvals.write",
      "description": "Delegated approve/reject capability for an agent (OBO).",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "agent-claims",
      "description": "Marks AI-agent tokens with subject_type=agent so a resource server can distinguish an agent caller from a human.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "subject_type",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "subject_type",
            "claim.value": "agent",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "service-claims",
      "description": "Marks service-account / workload tokens with subject_type=service so a resource server can distinguish a non-human workload acting as itself from a human.",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "subject_type",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "subject_type",
            "claim.value": "service",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "bank-web",
      "name": "Bank Web (confidential OIDC client)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "bank-web-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "*"
      ],
      "webOrigins": [
        "*"
      ],
      "attributes": {
        "post.logout.redirect.uris": "+"
      },
      "defaultClientScopes": [
        "bank-claims",
        "bank.read"
      ],
      "optionalClientScopes": [
        "bank.transactions.write",
        "bank.approvals.write"
      ]
    },
    {
      "clientId": "bank-shortlived",
      "name": "Bank short-lived token client (e2e expired-token tests)",
      "description": "Confidential password-grant client whose access tokens live 1 second, so tests can obtain a token that expires almost immediately and verify the 401 invalid_token / WWW-Authenticate handling. Not used by any application.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "bank-shortlived-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": true,
      "attributes": {
        "access.token.lifespan": "1"
      },
      "defaultClientScopes": [
        "bank-claims",
        "bank.read"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "bank-api",
      "name": "Bank API (resource server, bearer-only)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": true
    },
    {
      "clientId": "bank-workload",
      "name": "Bank Workload (service account / client credentials)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "bank-workload-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "bank-claims",
        "service-claims",
        "bank.read"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "bank-agent",
      "name": "Bank Agent (AI agent / MCP tool workload — client credentials)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "bank-agent-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "agent-claims",
        "agent.bank.read"
      ],
      "optionalClientScopes": [
        "agent.bank.transactions.write",
        "agent.bank.approvals.write"
      ]
    }
  ],
