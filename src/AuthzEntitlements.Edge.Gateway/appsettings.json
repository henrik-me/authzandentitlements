{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Realm": "authz-bank",
    "Audience": "bank-api"
  },
  "ReverseProxy": {
    "Routes": {
      "approvals-approve": {
        "ClusterId": "bank-api",
        "AuthorizationPolicy": "coarse.approvals.write",
        "Match": {
          "Path": "/api/transactions/{id}/approve",
          "Methods": [ "POST" ]
        }
      },
      "approvals-reject": {
        "ClusterId": "bank-api",
        "AuthorizationPolicy": "coarse.approvals.write",
        "Match": {
          "Path": "/api/transactions/{id}/reject",
          "Methods": [ "POST" ]
        }
      },
      "transactions-create": {
        "ClusterId": "bank-api",
        "AuthorizationPolicy": "coarse.transactions.write",
        "Match": {
          "Path": "/api/transactions",
          "Methods": [ "POST" ]
        }
      },
      "accounts-create": {
        "ClusterId": "bank-api",
        "AuthorizationPolicy": "coarse.authenticated",
        "Match": {
          "Path": "/api/accounts",
          "Methods": [ "POST" ]
        }
      },
      "read-catch-all": {
        "ClusterId": "bank-api",
        "AuthorizationPolicy": "coarse.read",
        "Match": {
          "Path": "/api/{**catch-all}",
          "Methods": [ "GET" ]
        }
      }
    },
    "Clusters": {
      "bank-api": {
        "Destinations": {
          "bank-api": {
            "Address": "http://localhost:5099/"
          }
        }
      }
    }
  }
}
