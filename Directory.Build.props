<Project>

  <PropertyGroup>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!--
      NU1902/NU1903 are NuGet audit advisories on transitive/preview packages we do
      not control at this .NET 10 RC / Aspire 13 preview stage (MessagePack via the
      Aspire.AppHost.Sdk dashboard/DCP; OpenTelemetry 1.14.0 from the ServiceDefaults
      template). TreatWarningsAsErrors promotes them to build errors during restore.
      Suppress only these two observed advisory codes so the compiler warnings-as-errors
      gate stays intact; NU1904 (critical) and other codes remain active. Revisit and
      remove when the upstream packages ship non-vulnerable stable releases.
    -->
    <NoWarn>$(NoWarn);NU1902;NU1903</NoWarn>
  </PropertyGroup>

</Project>
